# Add this to the server block that proxies FortiGate Backup Portal.
# It replaces raw 502/503/504 responses with the static maintenance page
# while Next.js is restarting during an update.

location = /maintenance.html {
    root /opt/fortigate-backup/public;
    internal;
}

location / {
    proxy_pass http://127.0.0.1:3000;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";

    proxy_intercept_errors on;
    error_page 502 503 504 /maintenance.html;
}
