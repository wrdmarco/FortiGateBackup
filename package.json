{
  "name": "fortigate-backup-portal",
  "version": "0.2.18",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma generate --schema prisma/legacy-sqlite/schema.prisma && next build",
    "start": "next start",
    "lint": "eslint .",
    "prisma:generate": "prisma generate",
    "prisma:generate:legacy": "prisma generate --schema prisma/legacy-sqlite/schema.prisma",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "worker": "tsx scripts/worker.ts",
    "health": "tsx scripts/healthcheck.ts",
    "telemetry:check": "tsx scripts/telemetry-diagnostics.ts",
    "test": "tsx test/run-tests.ts",
    "typecheck": "tsc --noEmit --pretty false --incremental false",
    "migrate:global-data": "tsx scripts/migrate-global-operational-data.ts",
    "break-glass:settings": "tsx scripts/create-break-glass-settings-link.ts",
    "setup:link": "tsx scripts/create-setup-link.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "next": "^16.2.10",
    "next-auth": "5.0.0-beta.31",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.13",
    "pdfkit": "^0.19.1",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "svg-to-pdfkit": "^0.1.8",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.20.1",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.12",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/svg-to-pdfkit": "^0.1.4",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "postcss": "^8.5.18",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.0.0 <25"
  }
}
